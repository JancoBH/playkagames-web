{
  "name": "playka-games",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node dist/PlaykaGames/server/server.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",

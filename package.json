    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-server": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@angular/ssr": "^21.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "express": "^5.1.0",
    "marked": "^17.0.5",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.4",
    "@angular/cli": "^21.2.4",
    "@angular/compiler-cli": "^21.2.6",
